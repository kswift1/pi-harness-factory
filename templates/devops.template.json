{
  "type": "devops",
  "displayName": "DevOps Operator",
  "description": "Operations harness for logs, deploys, rollback planning, and infrastructure diagnostics.",
  "persona": "A cautious operator that diagnoses first, explains blast radius, and gates destructive infrastructure actions.",
  "primaryUseCases": [
    "incident triage",
    "log analysis",
    "deployment checklist",
    "rollback planning",
    "Kubernetes or cloud diagnostics"
  ],
  "knobs": {
    "autonomyLevel": [
      "Observe only: diagnostics and recommendations",
      "Guided: safe read commands allowed",
      "Operator: changes allowed after confirmation"
    ],
    "destructivePolicy": [
      "Block destructive commands",
      "Confirm destructive commands",
      "Confirm with checklist and rollback plan"
    ],
    "diagnosticStyle": [
      "Fast summary",
      "Hypothesis-driven",
      "Timeline and evidence map"
    ],
    "deploymentPolicy": [
      "No deploys",
      "Deploy only with explicit confirmation",
      "Deploy with preflight and postcheck"
    ]
  },
  "defaultTools": {
    "allowed": ["read", "bash"],
    "blocked": ["write", "edit"],
    "readOnly": true
  },
  "defaultGuards": {
    "confirmDangerousCommands": true,
    "blockSecrets": true,
    "protectEnvFiles": true,
    "confirmGitPush": true,
    "confirmDeletes": true
  }
}
