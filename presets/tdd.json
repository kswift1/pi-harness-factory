  },
  "guards": {
    "confirmDangerousCommands": true,
    "blockSecrets": true,
    "protectEnvFiles": true,
    "confirmGitPush": true,
    "confirmDeletes": true
  },
  "workflow": {
    "requirePlanBeforeEdit": true,
    "runTestsAfterEdit": true,
    "summarizeChanges": true
  },
  "ui": {
    "statusLabel": "TDD",
    "themeHint": "green"
  },
  "memory": [
